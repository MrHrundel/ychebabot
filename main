user_schedules = {}
user_todo = {}
DAYS = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"]

class TodoFSM(StatesGroup):
    waiting_for_task = State()

class ScheduleFSM(StatesGroup):
    choosing_day = State()
    entering_tasks = State()

class AiSearchFSM(StatesGroup):
    waiting_for_question = State()

class SubjectCB(CallbackData, prefix="sub"):
    sub_id: int

class TopicCB(CallbackData, prefix="top"):
    sub_id: int
    top_id: int

# ==========================================
# 3. КЛАВИАТУРЫ
# ==========================================
def get_main_keyboard():
    return ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="📚 Предметы"), KeyboardButton(text="📅 Расписание")],
        [KeyboardButton(text="📝 Список дел"), KeyboardButton(text="🤖 ИИ Поиск")]
    ], resize_keyboard=True)

def get_todo_keyboard(user_id: int):
    builder = InlineKeyboardBuilder()
    tasks = user_todo.get(user_id, [])
    for idx, task in enumerate(tasks):
        status = "✅" if task["done"] else "❌"
        builder.row(
            InlineKeyboardButton(text=f"{status} {task['text']}", callback_data=f"todo_done_{idx}"),
            InlineKeyboardButton(text="🗑", callback_data=f"todo_del_{idx}")
        )
    builder.row(InlineKeyboardButton(text="➕ Добавить дело", callback_data="todo_add"))
    return builder.as_markup()

# ==========================================
# 4. ФУНКЦИЯ ЯНДЕКС ИИ
# ==========================================
async def ask_yandex_ai(query: str) -> str:
    url = "https://llm.api.cloud.yandex.net/foundationModels/v1/completion"
    headers = {"Authorization": f"Api-Key {YANDEX_API_KEY}", "x-folder-id": YANDEX_FOLDER_ID}
    payload = {
        "modelUri": f"gpt://{YANDEX_FOLDER_ID}/yandexgpt-lite",
        "completionOptions": {"stream": False, "temperature": 0.5, "maxTokens": 1000},
        "messages": [
            {"role": "system", "text": "Ты школьный помощник. Отвечай кратко и понятно."},
            {"role": "user", "text": query}
        ]
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(url, json=payload, headers=headers) as resp:
                if resp.status == 200:
                    result = await resp.json()
                    return result['result']['alternatives'][0]['message']['text']
                return f"Ошибка API: {resp.status}"
    except:
        return "Ошибка связи с ИИ."

# ==========================================
# 5. ОБРАБОТЧИКИ
# ==========================================

@router.message(CommandStart())
async def cmd_start(message: Message):
    await message.answer("Бот готов к работе!", reply_markup=get_main_keyboard())

# --- ЛОГИКА СПИСКА ДЕЛ ---
@router.message(F.text == "📝 Список дел")
async def show_todo(message: Message):
    await message.answer("Твой список дел:", reply_markup=get_todo_keyboard(message.from_user.id))

@router.callback_query(F.data == "todo_add")
async def todo_add_prompt(cq: CallbackQuery, state: FSMContext):
    await state.set_state(TodoFSM.waiting_for_task)
    await cq.message.answer("✍️ Напиши задачу:")
    await cq.answer()

@router.message(TodoFSM.waiting_for_task)
async def todo_add_save(message: Message, state: FSMContext):
    uid = message.from_user.id
    user_todo.setdefault(uid, []).append({"text": message.text, "done": False})
    await state.clear()
    await message.answer(f"✅ Задача '{message.text}' добавлена!", reply_markup=get_main_keyboard())
    await show_todo(message)

@router.callback_query(F.data.startswith("todo_done_"))
async def todo_toggle(cq: CallbackQuery):
    idx = int(cq.data.split("_")[2])
    uid = cq.from_user.id
    if uid in user_todo and len(user_todo[uid]) > idx:
        user_todo[uid][idx]["done"] = not user_todo[uid][idx]["done"]
        await cq.message.edit_reply_markup(reply_markup=get_todo_keyboard(uid))
    await cq.answer()

@router.callback_query(F.data.startswith("todo_del_"))
async def todo_delete(cq: CallbackQuery):
    idx = int(cq.data.split("_")[2])
    uid = cq.from_user.id
    if uid in user_todo and len(user_todo[uid]) > idx:
        user_todo[uid].pop(idx)
        await cq.message.edit_reply_markup(reply_markup=get_todo_keyboard(uid))
    await cq.answer()

# --- ЛОГИКА РАСПИСАНИЯ ---
@router.message(F.text == "📅 Расписание")
async def sch_start(message: Message, state: FSMContext):
    await state.set_state(ScheduleFSM.choosing_day)
    kb = [[KeyboardButton(text=d) for d in DAYS[:4]],
          [KeyboardButton(text=d) for d in DAYS[4:]],
          [KeyboardButton(text="📋 Посмотреть всё"), KeyboardButton(text="Отмена")]]
    await message.answer("Выбери день для записи или просмотри всё:", reply_markup=ReplyKeyboardMarkup(keyboard=kb, resize_keyboard=True))

@router.message(ScheduleFSM.choosing_day, F.text == "📋 Посмотреть всё")
async def sch_view_all(message: Message, state: FSMContext):
    uid = message.from_user.id
    sch = user_schedules.get(uid, {})
    text = "🗓 **Твоё расписание:**\n\n"
    for d in DAYS:
        text += f"📍 **{d}**: {sch.get(d, '—')}\n"
    await message.answer(text, parse_mode="Markdown", reply_markup=get_main_keyboard())
    await state.clear()

@router.message(ScheduleFSM.choosing_day, F.text.in_(DAYS))
async def sch_day_select(message: Message, state: FSMContext):
    await state.update_data(day=message.text)
    await state.set_state(ScheduleFSM.entering_tasks)
    await message.answer(f"📖 Что запишем на {message.text}?")

@router.message(ScheduleFSM.entering_tasks)
async def sch_save(message: Message, state: FSMContext):
    data = await state.get_data()
    user_schedules.setdefault(message.from_user.id, {})[data['day']] = message.text
    await state.clear()
    await message.answer(f"💾 Сохранено на {data['day']}!", reply_markup=get_main_keyboard())

# --- ИИ ПОИСК ---
@router.message(F.text == "🤖 ИИ Поиск")
async def ai_start(message: Message, state: FSMContext):
    await state.set_state(AiSearchFSM.waiting_for_question)
    await message.answer("🚀 Я слушаю! Задай любой школьный вопрос:")

@router.message(AiSearchFSM.waiting_for_question)
async def ai_proc(message: Message, state: FSMContext):
    await bot.send_chat_action(message.chat.id, "typing")
    ans = await ask_yandex_ai(message.text)
    await message.reply(ans, parse_mode="Markdown")
    await state.clear()

# --- ПРЕДМЕТЫ (ВЕРНУТЬ ИЗ ТВОЕГО КОДА) ---
@router.message(F.text == "📚 Предметы")
async def subjects(message: Message):
    # (Добавь сюда вызов клавиатуры предметов из прошлых этапов)
    await message.answer("Выбери предмет (настрой клавиатуру в коде)")

# ==========================================
# 6. ЗАПУСК
# ==========================================
async def main():
    dp.include_router(router)
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())

DAYS = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"]


class TodoFSM(StatesGroup):
    waiting_for_task = State()


class ScheduleFSM(StatesGroup):
    choosing_day = State()
    entering_tasks = State()


class AiSearchFSM(StatesGroup):
    waiting_for_question = State()


class SubjectCB(CallbackData, prefix="sub"):
    sub_id: int


class TopicCB(CallbackData, prefix="top"):
    sub_id: int
    top_id: int


# ==========================================
# 3. КЛАВИАТУРЫ
# ==========================================
def get_main_keyboard():
    return ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="📚 Предметы"), KeyboardButton(text="📅 Расписание")],
        [KeyboardButton(text="📝 Список дел"), KeyboardButton(text="🤖 ИИ Поиск")]  # Кнопка добавлена сюда
    ], resize_keyboard=True)


def get_subjects_keyboard():
    builder = InlineKeyboardBuilder()
    for s_id, s_name in SUBJECTS_MAP.items():
        builder.button(text=s_name, callback_data=SubjectCB(sub_id=s_id))
    builder.adjust(2)
    return builder.as_markup()


def get_topics_keyboard(sub_id: int):
    builder = InlineKeyboardBuilder()
    if sub_id in FORMULA_DB:
        for idx, topic in enumerate(FORMULA_DB[sub_id]):
            builder.button(text=topic["name"], callback_data=TopicCB(sub_id=sub_id, top_id=idx))
    builder.adjust(1)
    builder.row(InlineKeyboardButton(text="🔙 Назад", callback_data="back_to_subjects"))
    return builder.as_markup()


# ==========================================
# 4. ФУНКЦИЯ ЯНДЕКС ИИ
# ==========================================
async def ask_yandex_ai(query: str) -> str:
    url = "https://llm.api.cloud.yandex.net/foundationModels/v1/completion"
    headers = {"Authorization": f"Api-Key {YANDEX_API_KEY}", "x-folder-id": YANDEX_FOLDER_ID}
    payload = {
        "modelUri": f"gpt://{YANDEX_FOLDER_ID}/yandexgpt-lite",
        "completionOptions": {"stream": False, "temperature": 0.5, "maxTokens": "1500"},
        "messages": [
            {"role": "system", "text": "Ты умный школьный помощник. Отвечай развернуто и понятно. Используй Markdown."},
            {"role": "user", "text": query}
        ]
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(url, json=payload, headers=headers) as resp:
                if resp.status == 200:
                    result = await resp.json()
                    return result['result']['alternatives'][0]['message']['text']
                return f"Ошибка API Яндекса: {resp.status}. Проверь лимиты/права."
    except Exception:
        return "Ошибка соединения с ИИ."


# ==========================================
# 5. ОБРАБОТЧИКИ
# ==========================================

@router.message(CommandStart())
async def cmd_start(message: Message):
    await message.answer(
        "Привет! Я твой школьный помощник Довгаленко Станислава. Выбери нужный раздел на кнопках ниже.",
        reply_markup=get_main_keyboard())


# --- РЕЖИМ ИИ ПОИСКА ---
@router.message(F.text == "🤖 ИИ Поиск")
async def ai_search_start(message: Message, state: FSMContext):
    await state.set_state(AiSearchFSM.waiting_for_question)
    await message.answer(
        "🔍 **Режим ИИ-поиска активирован.**\nНапиши свой вопрос (например: 'Объясни закон Ома' или 'Кто написал Войну и мир?')",
        parse_mode="Markdown")


@router.message(AiSearchFSM.waiting_for_question)
async def ai_search_process(message: Message, state: FSMContext):
    if message.text == "Отмена":
        await state.clear()
        await message.answer("Поиск отменен.", reply_markup=get_main_keyboard())
        return

    await bot.send_chat_action(chat_id=message.chat.id, action="typing")
    answer = await ask_yandex_ai(message.text)

    await message.reply(answer, parse_mode="Markdown")
    # После ответа выходим из режима поиска, чтобы работали другие кнопки
    await state.clear()
    await message.answer("Чем еще я могу помочь?", reply_markup=get_main_keyboard())


# --- ПРЕДМЕТЫ ---
@router.message(F.text == "📚 Предметы")
async def show_subjects(message: Message):
    await message.answer("Выбери предмет:", reply_markup=get_subjects_keyboard())


@router.callback_query(F.data == "back_to_subjects")
async def back_to_sub(cq: CallbackQuery):
    await cq.message.edit_text("Выбери предмет:", reply_markup=get_subjects_keyboard())


@router.callback_query(SubjectCB.filter())
async def process_subject(cq: CallbackQuery, callback_data: SubjectCB):
    sub_id = callback_data.sub_id
    await cq.message.edit_text(f"Разделы ({SUBJECTS_MAP[sub_id]}):", reply_markup=get_topics_keyboard(sub_id))


@router.callback_query(TopicCB.filter())
async def process_topic(cq: CallbackQuery, callback_data: TopicCB):
    # Добавь проверку на существование данных в FORMULA_DB
    if callback_data.sub_id in FORMULA_DB and len(FORMULA_DB[callback_data.sub_id]) > callback_data.top_id:
        topic = FORMULA_DB[callback_data.sub_id][callback_data.top_id]
        text = f"📘 **Тема: {topic['name']}**\n\n📜 **Теория:**\n{topic['theory']}\n\n🔢 **Формулы:**\n" + "\n".join(
            [f"• `{f}`" for f in topic['formulas']])
        await cq.message.answer(text, parse_mode="Markdown")
    else:
        await cq.message.answer("Данные для этой темы пока не добавлены.")
    await cq.answer()


# --- СПИСОК ДЕЛ И РАСПИСАНИЕ (Оставляем как было) ---
@router.message(F.text == "📝 Список дел")
async def show_todo(message: Message):
    await message.answer("Твой список дел на сегодня.", reply_markup=get_main_keyboard())


@router.message(F.text == "📅 Расписание")
async def show_schedule(message: Message):
    await message.answer("Твоё расписание.", reply_markup=get_main_keyboard())


# ==========================================
# 6. ЗАПУСК
# ==========================================
async def main():
    dp.include_router(router)
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        pass

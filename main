            "theory": "Алгоритм — это четкая последовательность действий. Бывают линейные, разветвляющиеся и циклические алгоритмы. Для оценки эффективности используют сложность. В языке программирования (например, Python) переменная — это именованная область памяти. Индексы массивов (списков) начинаются с нуля.",
            "formulas": ["range(start, stop, step)", "len(array)", "if condition: else:", "while condition:"]
        }
    ]
}

# ==========================================
# 3. ХРАНИЛИЩЕ ДАННЫХ
# ==========================================
user_schedules = {} 
user_todo = {}      

# ==========================================
# 4. СОСТОЯНИЯ И КЛАВИАТУРЫ
# ==========================================
class TodoFSM(StatesGroup):
    waiting_for_task = State()

class ScheduleFSM(StatesGroup):
    choosing_day = State()
    entering_tasks = State()

class SubjectCB(CallbackData, prefix="sub"):
    sub_id: int

class TopicCB(CallbackData, prefix="top"):
    sub_id: int
    top_id: int

def get_main_keyboard():
    return ReplyKeyboardMarkup(keyboard=[
        [KeyboardButton(text="📚 Предметы"), KeyboardButton(text="📅 Расписание")],
        [KeyboardButton(text="📝 Список дел")]
    ], resize_keyboard=True)

def get_subjects_keyboard():
    builder = InlineKeyboardBuilder()
    for s_id, s_name in SUBJECTS_MAP.items():
        builder.button(text=s_name, callback_data=SubjectCB(sub_id=s_id))
    builder.adjust(2)
    return builder.as_markup()

def get_topics_keyboard(sub_id: int):
    builder = InlineKeyboardBuilder()
    if sub_id in FORMULA_DB:
        for idx, topic in enumerate(FORMULA_DB[sub_id]):
            builder.button(text=topic["name"], callback_data=TopicCB(sub_id=sub_id, top_id=idx))
    builder.adjust(1)
    builder.row(InlineKeyboardButton(text="🔙 Назад", callback_data="back_to_subjects"))
    return builder.as_markup()

# ==========================================
# 5. ОБРАБОТЧИКИ (ПРЕДМЕТЫ)
# ==========================================

@router.message(CommandStart())
async def cmd_start(message: Message):
    await message.answer("Привет! Я твой школьный справочник с полной теорией и формулами.", reply_markup=get_main_keyboard())

@router.message(F.text == "📚 Предметы")
async def show_subjects(message: Message):
    await message.answer("Выбери предмет:", reply_markup=get_subjects_keyboard())

@router.callback_query(F.data == "back_to_subjects")
async def back_to_sub(cq: CallbackQuery):
    await cq.message.edit_text("Выбери предмет:", reply_markup=get_subjects_keyboard())

@router.callback_query(SubjectCB.filter())
async def process_subject(cq: CallbackQuery, callback_data: SubjectCB):
    sub_id = callback_data.sub_id
    await cq.message.edit_text(f"Разделы ({SUBJECTS_MAP[sub_id]}):", reply_markup=get_topics_keyboard(sub_id))

@router.callback_query(TopicCB.filter())
async def process_topic(cq: CallbackQuery, callback_data: TopicCB):
    topic = FORMULA_DB[callback_data.sub_id][callback_data.top_id]
    text = (
        f"📘 **Тема: {topic['name']}**\n\n"
        f"📜 **Теория:**\n_{topic['theory']}_\n\n"
        f"🔢 **Формулы:**\n" + "\n".join([f"• `{f}`" for f in topic['formulas']])
    )
    await cq.message.answer(text, parse_mode="Markdown")
    await cq.answer()

# ==========================================
# 6. ОБРАБОТЧИКИ (СПИСОК ДЕЛ)
# ==========================================

def get_todo_keyboard(user_id: int):
    builder = InlineKeyboardBuilder()
    tasks = user_todo.get(user_id, [])
    for idx, task in enumerate(tasks):
        status = "✅" if task["done"] else "❌"
        builder.row(
            InlineKeyboardButton(text=f"{status} {task['text']}", callback_data=f"todo_done_{idx}"),
            InlineKeyboardButton(text="🗑", callback_data=f"todo_del_{idx}")
        )
    builder.row(InlineKeyboardButton(text="➕ Добавить дело", callback_data="todo_add"))
    return builder.as_markup()

@router.message(F.text == "📝 Список дел")
async def show_todo(message: Message):
    await message.answer("Твой To-Do лист:", reply_markup=get_todo_keyboard(message.from_user.id))

@router.callback_query(F.data == "todo_add")
async def todo_add_prompt(cq: CallbackQuery, state: FSMContext):
    await state.set_state(TodoFSM.waiting_for_task)
    await cq.message.answer("Введите текст новой задачи:")
    await cq.answer()

@router.message(TodoFSM.waiting_for_task)
async def todo_add_save(message: Message, state: FSMContext):
    uid = message.from_user.id
    user_todo.setdefault(uid, []).append({"text": message.text, "done": False})
    await state.clear()
    await message.answer(f"Задача сохранена!", reply_markup=get_main_keyboard())
    await show_todo(message)

@router.callback_query(F.data.startswith("todo_done_"))
async def todo_toggle(cq: CallbackQuery):
    idx = int(cq.data.split("_")[2])
    uid = cq.from_user.id
    if uid in user_todo and len(user_todo[uid]) > idx:
        user_todo[uid][idx]["done"] = not user_todo[uid][idx]["done"]
        await cq.message.edit_reply_markup(reply_markup=get_todo_keyboard(uid))
    await cq.answer()

@router.callback_query(F.data.startswith("todo_del_"))
async def todo_delete(cq: CallbackQuery):
    idx = int(cq.data.split("_")[2])
    uid = cq.from_user.id
    if uid in user_todo and len(user_todo[uid]) > idx:
        user_todo[uid].pop(idx)
        await cq.message.edit_reply_markup(reply_markup=get_todo_keyboard(uid))
    await cq.answer()

# ==========================================
# 7. РАСПИСАНИЕ (+ ПОСМОТРЕТЬ ВСЁ)
# ==========================================
DAYS = ["Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс"]

@router.message(F.text == "📅 Расписание")
async def sch_start(message: Message, state: FSMContext):
    await state.set_state(ScheduleFSM.choosing_day)
    kb = [
        [KeyboardButton(text=d) for d in DAYS[:4]],
        [KeyboardButton(text=d) for d in DAYS[4:]],
        [KeyboardButton(text="📋 Посмотреть всё"), KeyboardButton(text="Отмена")]
    ]
    await message.answer("Выбери день или нажми 'Посмотреть всё':", reply_markup=ReplyKeyboardMarkup(keyboard=kb, resize_keyboard=True))

@router.message(ScheduleFSM.choosing_day, F.text == "📋 Посмотреть всё")
async def sch_view_all(message: Message, state: FSMContext):
    uid = message.from_user.id
    schedule = user_schedules.get(uid, {})
    if not schedule:
        await message.answer("Расписание пока пусто.")
    else:
        text = "🗓 **Твоё расписание на неделю:**\n\n"
        for day in DAYS:
            task = schedule.get(day, "_Пусто_")
            text += f"📍 **{day}**: {task}\n"
        await message.answer(text, parse_mode="Markdown")
    await state.clear()
    await message.answer("Меню:", reply_markup=get_main_keyboard())

@router.message(ScheduleFSM.choosing_day, F.text.in_(DAYS))
async def sch_day(message: Message, state: FSMContext):
    await state.update_data(day=message.text)
    await state.set_state(ScheduleFSM.entering_tasks)
    await message.answer(f"Что добавим в расписание на {message.text}?")

@router.message(ScheduleFSM.entering_tasks)
async def sch_save(message: Message, state: FSMContext):
    data = await state.get_data()
    user_schedules.setdefault(message.from_user.id, {})[data['day']] = message.text
    await message.answer(f"Сохранено для {data['day']}!", reply_markup=get_main_keyboard())
    await state.clear()

@router.message(F.text == "Отмена")
async def cmd_cancel(message: Message, state: FSMContext):
    await state.clear()
    await message.answer("Отменено.", reply_markup=get_main_keyboard())

# ==========================================
# 8. ЗАПУСК
# ==========================================
async def main():
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        pass
